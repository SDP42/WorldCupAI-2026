{
    "model_name": "ANN",
    "framework": "PyTorch",
    "input_dim": 37,
    "hidden_dims": [
        256,
        128,
        64
    ],
    "dropout_rates": [
        0.3,
        0.3,
        0.2
    ],
    "n_classes": 3,
    "activation": "ReLU",
    "batch_norm": true,
    "weight_init": "kaiming_uniform (He)",
    "optimizer": "AdamW",
    "lr": 0.001,
    "weight_decay": 0.0001,
    "batch_size": 256,
    "loss": "LabelSmoothingCrossEntropy(smoothing=0.05)",
    "lr_scheduler": "ReduceLROnPlateau(factor=0.5, patience=5)",
    "early_stopping": "patience=15, min_delta=1e-4",
    "max_epochs": 200
}